#!/usr/bin/env bash
set -euo pipefail

# Render help for the local setup helper.
usage() {
  cat <<'EOF'
Usage: bin/setup

Create or refresh a single `jiggit` symlink in one writable directory from the
current PATH. When several writable PATH directories exist, setup prompts for
which one to use.
EOF
}

# Resolve one script path through any symlink chain.
resolve_script_path() {
  local source_path="${1}"
  local source_dir=""
  local next_path=""

  while [[ -L "${source_path}" ]]; do
    source_dir="$(cd -P "$(dirname "${source_path}")" > /dev/null 2>&1 && pwd)"
    next_path="$(readlink "${source_path}")"
    if [[ "${next_path}" != /* ]]; then
      source_path="${source_dir}/${next_path}"
    else
      source_path="${next_path}"
    fi
  done

  source_dir="$(cd -P "$(dirname "${source_path}")" > /dev/null 2>&1 && pwd)"
  printf '%s/%s\n' "${source_dir}" "$(basename "${source_path}")"
}

# Return the absolute repo root for the current checkout.
setup_repo_root() {
  local script_path

  script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
  cd -P "$(dirname "${script_path}")/.." > /dev/null 2>&1
  pwd
}

# Return the absolute jiggit executable path for this checkout.
setup_command_target() {
  printf '%s/bin/jiggit\n' "$(setup_repo_root)"
}

# Return a newline-delimited list of existing PATH directories.
path_directories() {
  local path_value="${PATH:-}"
  local old_ifs="${IFS}"
  local candidate_dir

  IFS=':'
  for candidate_dir in ${path_value}; do
    [[ -n "${candidate_dir}" ]] || continue
    [[ -d "${candidate_dir}" ]] || continue
    printf '%s\n' "${candidate_dir}"
  done
  IFS="${old_ifs}"
}

# Return success when two paths resolve to the same filesystem entry.
same_file() {
  local left_path="${1:-}"
  local right_path="${2:-}"

  [[ -e "${left_path}" ]] && [[ -e "${right_path}" ]] && [[ "${left_path}" -ef "${right_path}" ]]
}

# Return the first PATH directory that already exposes this checkout's jiggit command.
existing_link_dir_for_target() {
  local target_path="${1}"
  local candidate_dir
  local candidate_path

  while IFS= read -r candidate_dir; do
    candidate_path="${candidate_dir}/jiggit"
    if same_file "${candidate_path}" "${target_path}"; then
      printf '%s\n' "${candidate_dir}"
      return 0
    fi
  done < <(path_directories)

  return 1
}

# Return newline-delimited writable PATH directories, de-duplicated in order.
collect_writable_path_dirs() {
  local candidate_dir
  local seen_dirs=""

  while IFS= read -r candidate_dir; do
    [[ -w "${candidate_dir}" ]] || continue
    if printf '%s\n' "${seen_dirs}" | grep -Fx -- "${candidate_dir}" > /dev/null 2>&1; then
      continue
    fi
    seen_dirs="${seen_dirs}${candidate_dir}
"
    printf '%s\n' "${candidate_dir}"
  done < <(path_directories)
}

# Read one prompt response from stdin when available, otherwise /dev/tty.
read_prompt_choice() {
  local choice=""

  if IFS= read -r choice; then
    printf '%s\n' "${choice}"
    return 0
  fi

  if exec 3<> /dev/tty 2>/dev/null; then
    if IFS= read -r choice <&3; then
      exec 3<&-
      exec 3>&-
      printf '%s\n' "${choice}"
      return 0
    fi
    exec 3<&-
    exec 3>&-
  fi

  return 1
}

# Prompt the user to select one writable PATH directory.
prompt_for_link_dir() {
  local -a candidate_dirs=("$@")
  local choice=""

  printf "Choose a PATH directory for the \`jiggit\` symlink:\n" >&2

  local index=0
  local candidate_dir
  for candidate_dir in "${candidate_dirs[@]}"; do
    index=$((index + 1))
    printf '  %s. %s\n' "${index}" "${candidate_dir}" >&2
  done

  while true; do
    printf 'Selection [1-%s]: ' "${#candidate_dirs[@]}" >&2
    if ! choice="$(read_prompt_choice)"; then
      printf '\nUnable to read a PATH selection.\n' >&2
      return 1
    fi

    if [[ "${choice}" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidate_dirs[@]} )); then
      printf '%s\n' "${candidate_dirs[$((choice - 1))]}"
      return 0
    fi

    printf 'Invalid selection. Enter a number from 1 to %s.\n' "${#candidate_dirs[@]}" >&2
  done
}

# Choose the PATH directory where the jiggit symlink should live.
select_link_dir() {
  local target_path="${1}"
  local explicit_link_dir="${JIGGIT_LINK_DIR:-}"
  local existing_link_dir=""
  local -a candidate_dirs=()
  local candidate_dir

  if [[ -n "${explicit_link_dir}" ]]; then
    if [[ ! -d "${explicit_link_dir}" ]]; then
      printf 'Configured link directory does not exist: %s\n' "${explicit_link_dir}" >&2
      return 1
    fi
    if [[ ! -w "${explicit_link_dir}" ]]; then
      printf 'Configured link directory is not writable: %s\n' "${explicit_link_dir}" >&2
      return 1
    fi
    printf '%s\n' "${explicit_link_dir}"
    return 0
  fi

  if existing_link_dir="$(existing_link_dir_for_target "${target_path}" 2>/dev/null)"; then
    printf '%s\n' "${existing_link_dir}"
    return 0
  fi

  while IFS= read -r candidate_dir; do
    candidate_dirs+=("${candidate_dir}")
  done < <(collect_writable_path_dirs)
  if [[ ${#candidate_dirs[@]} -eq 0 ]]; then
    printf "No writable PATH directories are available for the \`jiggit\` symlink.\n" >&2
    return 1
  fi

  if [[ ${#candidate_dirs[@]} -eq 1 ]]; then
    printf '%s\n' "${candidate_dirs[0]}"
    return 0
  fi

  prompt_for_link_dir "${candidate_dirs[@]}"
}

# Create or refresh the managed jiggit symlink in the chosen PATH directory.
ensure_jiggit_symlink() {
  local link_dir="${1}"
  local target_path="${2}"
  local symlink_path="${link_dir}/jiggit"

  if same_file "${symlink_path}" "${target_path}"; then
    printf 'already-linked\n'
    return 0
  fi

  if [[ -e "${symlink_path}" || -L "${symlink_path}" ]]; then
    printf 'Refusing to replace an existing command at %s\n' "${symlink_path}" >&2
    return 1
  fi

  ln -s "${target_path}" "${symlink_path}"
  printf 'linked\n'
}

# Print the setup result and next step instructions.
render_setup_summary() {
  local repo_root="${1}"
  local target_path="${2}"
  local link_dir="${3}"
  local status="${4}"

  printf '# jiggit setup\n\n'
  printf -- "- repo root: \`%s\`\n" "${repo_root}"
  printf -- "- command target: \`%s\`\n" "${target_path}"
  printf -- "- link dir: \`%s\`\n" "${link_dir}"
  printf -- "- status: \`%s\`\n" "${status}"
  printf -- "- next step: \`jiggit --version\`\n"
}

# Choose one PATH directory, create the symlink, and print the result.
run_main() {
  local repo_root
  local target_path
  local link_dir
  local status

  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    return 0
  fi

  repo_root="$(setup_repo_root)"
  target_path="$(setup_command_target)"
  link_dir="$(select_link_dir "${target_path}")"
  status="$(ensure_jiggit_symlink "${link_dir}" "${target_path}")"

  render_setup_summary "${repo_root}" "${target_path}" "${link_dir}" "${status}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  run_main "$@"
fi
