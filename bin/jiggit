#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

if [[ "${1-}" == "source" ]]; then
  JIGGIT_SOURCE_ONLY=1
  shift || true
else
  JIGGIT_SOURCE_ONLY=0
fi

JIGGIT_SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${JIGGIT_SCRIPT_PATH}" ]]; do
  JIGGIT_SCRIPT_DIR="$(cd -P "$(dirname "${JIGGIT_SCRIPT_PATH}")" > /dev/null 2>&1 && pwd)"
  JIGGIT_NEXT_PATH="$(readlink "${JIGGIT_SCRIPT_PATH}")"
  if [[ "${JIGGIT_NEXT_PATH}" != /* ]]; then
    JIGGIT_SCRIPT_PATH="${JIGGIT_SCRIPT_DIR}/${JIGGIT_NEXT_PATH}"
  else
    JIGGIT_SCRIPT_PATH="${JIGGIT_NEXT_PATH}"
  fi
done
JIGGIT_SCRIPT_DIR="$(cd -P "$(dirname "${JIGGIT_SCRIPT_PATH}")" > /dev/null 2>&1 && pwd)"
JIGGIT_REPO_ROOT="$(cd -P "${JIGGIT_SCRIPT_DIR}/.." > /dev/null 2>&1 && pwd)"
readonly JIGGIT_SCRIPT_PATH
readonly JIGGIT_SCRIPT_DIR
readonly JIGGIT_REPO_ROOT
unset JIGGIT_NEXT_PATH

JIGGIT_FLAG_VERBOSE=0
JIGGIT_GLOBAL_PROJECTS_VALUE=""
JIGGIT_GLOBAL_ALL_PROJECTS=0
JIGGIT_COLOR_ENABLED=0
JIGGIT_REPO_READY=0
JIGGIT_STRIPPED_ARGS=()
JIGGIT_POSITIONAL_ARGS=()

# Return the tracked jiggit version from the checkout metadata.
jiggit_version() {
  local version_file="${JIGGIT_REPO_ROOT}/VERSION"

  if [[ -f "${version_file}" ]]; then
    tr -d '\n' < "${version_file}"
    return 0
  fi

  printf 'unknown\n'
}

# Reset the top-level jiggit CLI state before parsing a new argv.
jiggit_reset_state() {
  JIGGIT_FLAG_VERBOSE=0
  JIGGIT_GLOBAL_PROJECTS_VALUE=""
  JIGGIT_GLOBAL_ALL_PROJECTS=0
  JIGGIT_STRIPPED_ARGS=()
  JIGGIT_POSITIONAL_ARGS=()
}

# Print text with optional ANSI styling.
color_print() {
  local style="${1:-}"
  shift || true

  if [[ "${JIGGIT_COLOR_ENABLED:-0}" -eq 1 && -n "${style}" ]]; then
    printf '%b%s%b\n' "${style}" "$*" $'\033[0m'
    return 0
  fi

  printf '%s\n' "$*"
}

# Print a styled informational line.
jiggit_info() {
  color_print $'\033[1;36m' "$*"
}

# Print one styled heading line for help output.
jiggit_help_heading() {
  color_print $'\033[1;36m' "$*"
}

# Print one styled command or option label for help output.
jiggit_help_label() {
  color_print $'\033[1;32m' "$*"
}

# Render one help line with optional heading/label styling.
jiggit_render_help_line() {
  local line="${1:-}"

  case "${line}" in
    "Usage:"|"Commands:"|"  Global flags:")
      jiggit_help_heading "${line}"
      ;;
    "    --"*|"  help"|"  version, --version"|"  assign-fix-version "*|"  changelog "*|"  config "*|"  compare "*|"  dash "*|"  doctor "*|"  diagnostics "*|"  env-diff "*|"  env-versions "*|"  explore "*|"  jira-check "*|"  jira-setup "*|"  jira-create "*|"  jira-issues "*|"  next-release "*|"  overview "*|"  release-notes "*|"  releases "*)
      jiggit_help_label "${line}"
      ;;
    *)
      printf '%s\n' "${line}"
      ;;
  esac
}

# Return success when top-level verbose mode is enabled.
jiggit_is_verbose() {
  [[ "${JIGGIT_FLAG_VERBOSE:-0}" -eq 1 ]]
}

# Print a styled warning line.
jiggit_warn() {
  color_print $'\033[1;33m' "$*" >&2
}

# Print a styled error line.
jiggit_error() {
  color_print $'\033[1;31m' "$*" >&2
}

# Enable the shared verbose troubleshooting mode for all subcommands.
enable_verbose_mode() {
  JIGGIT_FLAG_VERBOSE=1
  export JIGGIT_VERBOSE=1
  export VERBOSE=true
  export JIGGIT_EXPLORE_VERBOSE=1
  export JIGGIT_ENV_VERSIONS_VERBOSE=1
  export JIGGIT_ENV_DIFF_VERBOSE=1
}

# Remove any --verbose flags from the provided argv while enabling verbose mode.
strip_verbose_flags() {
  local arg

  JIGGIT_STRIPPED_ARGS=()
  for arg in "$@"; do
    if [[ "${arg}" == "--verbose" ]]; then
      enable_verbose_mode
      continue
    fi
    JIGGIT_STRIPPED_ARGS+=("${arg}")
  done
}

# Source the subcommand implementations from the repository checkout.
jiggit_load_commands() {
  # shellcheck source=bin/lib/explore.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/explore.sh"
  # shellcheck source=bin/lib/assign_fix_version_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/assign_fix_version_command.sh"
  # shellcheck source=bin/lib/changelog_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/changelog_command.sh"
  # shellcheck source=bin/lib/compare_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/compare_command.sh"
  # shellcheck source=bin/lib/config_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/config_command.sh"
  # shellcheck source=bin/lib/doctor_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/doctor_command.sh"
  # shellcheck source=bin/lib/env_diff_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/env_diff_command.sh"
  # shellcheck source=bin/lib/env_versions_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/env_versions_command.sh"
  # shellcheck source=bin/lib/jira_create.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/jira_create.sh"
  # shellcheck source=bin/lib/jira_check_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/jira_check_command.sh"
  # shellcheck source=bin/lib/jira_setup_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/jira_setup_command.sh"
  # shellcheck source=bin/lib/jira_issues_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/jira_issues_command.sh"
  # shellcheck source=bin/lib/next_release_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/next_release_command.sh"
  # shellcheck source=bin/lib/overview_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/overview_command.sh"
  # shellcheck source=bin/lib/release_notes_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/release_notes_command.sh"
  # shellcheck source=bin/lib/releases_command.sh
  source "${JIGGIT_REPO_ROOT}/bin/lib/releases_command.sh"
}

# Render the top-level CLI help for jiggit subcommands.
jiggit_usage() {
  local line

  while IFS= read -r line; do
    jiggit_render_help_line "${line}"
  done <<'USAGE'
Usage:
  jiggit [--projects=<project[,project...]>] [--all-projects] [--verbose] <command> ...
  jiggit --version
  jiggit assign-fix-version [<project|path>] --release <fixVersion> [--base <env|git-ref>] [--target <git-ref>] [--verbose]
  jiggit help
  jiggit version
  jiggit changelog [<project|path>] --from <git-ref> --to <git-ref> [--verbose]
  jiggit config [--global|--no-projects] [<project|path> ...] [--verbose]
  jiggit compare [<project|path>] --from <git-ref> --to <git-ref> [--verbose]
  jiggit dash [<project|path> ...] [--verbose]
  jiggit doctor [--global|--no-projects] [--fail-fast] [--ignore-failures] [<project|path> ...] [--verbose]
  jiggit diagnostics [--global|--no-projects] [--fail-fast] [--ignore-failures] [<project|path> ...] [--verbose]
  jiggit env-diff [<project|path>] --base <env|git-ref> [--target <env|git-ref>] [--verbose]
  jiggit env-versions [<project|path>] [--verbose]
  jiggit explore [--verbose] [--dry-run] [--append|--replace] <dir> [<dir> ...]
  jiggit jira-check [<project|path>] [--all] [--verbose]
  jiggit jira-setup [<jira-name>] [--verbose]
  jiggit jira-create [<project|path>] [--commit <git-ref>] [--type <issue-type>] [--summary <text>] [--dry-run] [--verbose]
  jiggit jira-issues [<project|path>] --release <fixVersion> [--verbose]
  jiggit next-release [<project|path>] [--base <env|git-ref>] [--target <git-ref>] [--verbose]
  jiggit overview [<project|path> ...] [--verbose]
  jiggit release-notes [<project|path>] --target <git-ref|release> [--from-env <env>] [--from <git-ref>] [--verbose]
  jiggit releases [<project|path>] [--verbose]

Commands:
  Global flags:
    --verbose
      Enable troubleshooting output for the selected subcommand.

    --projects=a,b
      Override cwd-based project selection with one or more configured ids or
      paths. Single-project commands require exactly one selector.

    --all-projects
      Break out of cwd-based single-project mode and operate on all configured
      projects where the selected command supports it.

  help
    Show this help text.

  version, --version
    Show the installed jiggit version.

  assign-fix-version [<project|path>] --release <fixVersion> [--base <env|git-ref>] [--target <git-ref>] [--verbose]
    Add the chosen Jira fixVersion to issues in the base-to-target commit span
    when they do not already have it.

  changelog [<project|path>] --from <git-ref> --to <git-ref> [--verbose]
    Show a Markdown changelog grouped by conventional commit type.

  config [--global|--no-projects] [<project|path> ...] [--verbose]
    Show the effective merged config and where each project entry came from.

  compare [<project|path>] --from <git-ref> --to <git-ref> [--verbose]
    Show a Markdown compare report with normalized refs, commit count,
    Jira keys, and compare URL when available.

  dash [<project|path> ...] [--verbose]
    Alias for `overview`.

  doctor [--global|--no-projects] [--fail-fast] [--ignore-failures] [<project|path> ...] [--verbose]
    Alias: `diagnostics`.

    Run health checks for configured projects. Defaults to all configured
    projects. In interactive mode, missing config can be scaffolded with a preview before writing.

  diagnostics [--fail-fast] [--ignore-failures] [<project|path> ...] [--verbose]
    Run health checks for configured projects. Defaults to all configured
    projects. In interactive mode, missing config can be scaffolded with a preview before writing.

  env-diff [<project|path>] --base <env|git-ref> [--target <env|git-ref>] [--verbose]
    Show the code difference between a base environment and a target
    environment or latest git ref.

  env-versions [<project|path>] [--verbose]
    Show deployed versions for the project's configured environments.

  explore [--verbose] [--dry-run] [--append|--replace] <dir> [<dir> ...]
    Scan directories for git repositories and generate reviewable
    candidate entries in ~/.jiggit/discovered_projects.toml.

  jira-check [<project|path>] [--all] [--verbose]
    Verify Jira connectivity and project access for the configured project.

  jira-setup [<jira-name>] [--verbose]
    Interactively create or repair Jira auth config.

  jira-create [<project|path>] [--commit <git-ref>] [--type <issue-type>] [--summary <text>] [--dry-run] [--verbose]
    Create a Jira issue in the configured Jira project based on a
    commit message from the project's git repository.

  jira-issues [<project|path>] --release <fixVersion> [--verbose]
    Show Jira issues for a release/fixVersion, using fuzzy release matching.

  next-release [<project|path>] [--base <env|git-ref>] [--target <git-ref>] [--verbose]
    Detect whether a project needs a new release and suggest the next
    minor version from the configured base.

  overview [<project|path> ...] [--verbose]
    Show a read-only dashboard for one configured project or all configured
    projects.

  release-notes [<project|path>] --target <git-ref|release> [--from-env <env>] [--from <git-ref>] [--verbose]
    Generate git-first release notes enriched with Jira metadata.

  releases [<project|path>] [--verbose]
    List Jira releases/fixVersions for the configured Jira project.
USAGE
}

# Parse top-level project-scope flags before dispatching to a subcommand.
parse_opts() {
  jiggit_reset_state
  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --projects=*)
        JIGGIT_GLOBAL_PROJECTS_VALUE="${1#--projects=}"
        shift
        ;;
      --projects)
        if [[ $# -lt 2 ]]; then
          jiggit_error "Missing value for --projects"
      jiggit_usage >&2
      return 2
        fi
        JIGGIT_GLOBAL_PROJECTS_VALUE="${2}"
        shift 2
        ;;
      --all-projects)
        JIGGIT_GLOBAL_ALL_PROJECTS=1
        shift
        ;;
      -h|--help)
        JIGGIT_POSITIONAL_ARGS=("help")
        break
        ;;
      --version)
        JIGGIT_POSITIONAL_ARGS=("version")
        break
        ;;
      --verbose)
        enable_verbose_mode
        shift
        ;;
      --)
        shift
        JIGGIT_POSITIONAL_ARGS=("$@")
        break
        ;;
      -*)
        jiggit_warn "Unknown option: ${1}"
        jiggit_usage >&2
        return 2
        ;;
      *)
        JIGGIT_POSITIONAL_ARGS=("$@")
        break
        ;;
    esac
  done

  if [[ ${#JIGGIT_POSITIONAL_ARGS[@]} -eq 0 ]]; then
    JIGGIT_POSITIONAL_ARGS=("help")
  fi

  strip_verbose_flags "${JIGGIT_POSITIONAL_ARGS[@]}"
}

# Detect terminal capabilities and prepare the runtime environment.
parse_prereqs() {
  if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    JIGGIT_COLOR_ENABLED=1
  else
    JIGGIT_COLOR_ENABLED=0
  fi

  if [[ -n "${JIGGIT_GLOBAL_PROJECTS_VALUE}" ]]; then
    export JIGGIT_PROJECT_SELECTORS="${JIGGIT_GLOBAL_PROJECTS_VALUE}"
  else
    unset JIGGIT_PROJECT_SELECTORS || true
  fi
  export JIGGIT_ALL_PROJECTS="${JIGGIT_GLOBAL_ALL_PROJECTS}"
}

# Change into the repo root once before command dispatch.
jiggit_enter_repo_root() {
  if [[ "${JIGGIT_REPO_READY:-0}" -eq 1 ]]; then
    return 0
  fi

  pushd "${JIGGIT_REPO_ROOT}" > /dev/null || {
    jiggit_error "Failed to enter repo root: ${JIGGIT_REPO_ROOT}"
    return 1
  }
  JIGGIT_REPO_READY=1
}

# Dispatch the selected jiggit subcommand to its implementation.
dispatch_command() {
  local command="${1:-help}"

  case "${command}" in
    version|--version)
      printf 'jiggit %s\n' "$(jiggit_version)"
      ;;
    help|-h|--help)
      usage
      ;;
    assign-fix-version)
      shift || true
      run_assign_fix_version_main "$@"
      ;;
    changelog)
      shift || true
      run_changelog_main "$@"
      ;;
    config)
      shift || true
      run_config_main "$@"
      ;;
    compare)
      shift || true
      run_compare_main "$@"
      ;;
    dash)
      shift || true
      run_overview_main "$@"
      ;;
    doctor)
      shift || true
      run_doctor_main "$@"
      ;;
    diagnostics)
      shift || true
      run_doctor_main "$@"
      ;;
    env-diff)
      shift || true
      run_env_diff_main "$@"
      ;;
    env-versions)
      shift || true
      run_env_versions_main "$@"
      ;;
    explore)
      shift || true
      run_explore_main "$@"
      ;;
    jira-check)
      shift || true
      run_jira_check_main "$@"
      ;;
    jira-setup)
      shift || true
      run_jira_setup_main "$@"
      ;;
    jira-create)
      shift || true
      run_jira_create_main "$@"
      ;;
    jira-issues)
      shift || true
      run_jira_issues_main "$@"
      ;;
    next-release)
      shift || true
      run_next_release_main "$@"
      ;;
    overview)
      shift || true
      run_overview_main "$@"
      ;;
    release-notes)
      shift || true
      run_release_notes_main "$@"
      ;;
    releases)
      shift || true
      run_releases_main "$@"
      ;;
    *)
      jiggit_error "Unknown command: ${command}"
      printf '\n' >&2
      jiggit_usage >&2
      return 1
      ;;
  esac
}

# Parse, prepare, and dispatch the requested jiggit command.
jiggit_run_main() {
  parse_opts "$@" || return $?
  parse_prereqs || return $?
  jiggit_enter_repo_root || return $?
  dispatch_command "${JIGGIT_STRIPPED_ARGS[@]}"
}

jiggit_load_commands

# Reclaim the public entrypoint name after sourcing helpers that may define run_main.
usage() {
  jiggit_usage
}

# Reclaim the public entrypoint name after sourcing helpers that may define run_main.
run_main() {
  jiggit_run_main "$@"
}

if (( ! JIGGIT_SOURCE_ONLY )); then
  run_main "$@"
fi
